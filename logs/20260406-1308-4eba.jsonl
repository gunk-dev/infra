     pkgs.flyctl\n            pkgs.cue\n            pkgs.skopeo\n            pkgs.nixfmt\n          ];\n        };\n      }\n    );\n}\n","structuredPatch":[{"oldStart":4,"oldLines":7,"newStart":4,"newLines":7,"lines":["   inputs = {","     nixpkgs.url = \"github:NixOS/nixpkgs/nixpkgs-unstable\";","     flake-utils.url = \"github:numtide/flake-utils\";","-    flux.url = \"github:patflynn/flux\";","+    flux.url = \"github:gunk-dev/flux\";","   };"," ","   outputs ="]}],"userModified":false,"replaceAll":false}}
